ANTHROPIC_API_KEY=your_anthropic_api_key_here
ENVIRONMENT=development
MAX_FILE_SIZE_MB=10
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://foliox.vercel.app
AMFI_CACHE_TTL_HOURS=24
SESSION_TTL_MINUTES=30

# MongoDB (Session and Auth)
MONGODB_URL=mongodb://localhost:27017/
MONGODB_DB_NAME=foliox_db

# Auth
JWT_SECRET=your_super_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24h
EOF
